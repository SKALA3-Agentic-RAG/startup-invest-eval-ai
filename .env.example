OPENAI_API_KEY=sk-...
TAVILY_API_KEY=tvly-...

# Hugging Face (optional unless the embedding model is gated)
# HF_TOKEN=
# QWEN_EMBEDDING_DEVICE=cuda
# Embedding weights cache (default: ./models/huggingface under the project root)
# HF_MODEL_CACHE_PATH=/absolute/or/relative/path
# Set 1 to force local-only model loading (no Hugging Face network access)
# HF_LOCAL_FILES_ONLY=1
# PDF folder for tools/ingest_pdfs.py (default: ./data/pdfs)
# PDF_SOURCE_DIR=/path/to/pdfs
# engine=auto: use pdfplumber when enough tables are found (within scan window)
# PDF_AUTO_MIN_TABLES=2
# PDF_AUTO_TABLE_SCAN_MAX_PAGES=   # empty = all pages; positive = first N pages only
# OpenAI rate-limit controls (lower values = fewer concurrent requests)
# MAX_PARALLEL_STARTUP_EVALS=2
# MAX_PARALLEL_SEARCH_ENRICH=3
# OPENAI_RETRY_MAX_ATTEMPTS=4
# OPENAI_RETRY_BASE_SECONDS=1.5
# FAISS retrieval tuning (accuracy/recall trade-off for Hit Rate@k, MRR)
# RAG_FETCH_K=30
# RAG_MMR_LAMBDA=0.35
